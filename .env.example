# 管理员密码（用于访问反馈管理后台）
# 请务必修改此密码，不要使用默认值
VITE_ADMIN_PASSWORD=your-secure-password

# 反馈API服务器地址
# 开发环境: http://localhost:3001/api
# 生产环境: https://www.iching64.fun/api
VITE_FEEDBACK_API_URL=/api

# OpenAI API 配置（用于AI解卦功能）
# OpenAI API Key - 请替换为您的API密钥
OPENAI_API_KEY=your-openai-api-key-here
# OpenAI 模型，默认使用 gpt-4o-mini，可选 gpt-4o, gpt-4-turbo 等
OPENAI_MODEL=gpt-4o-mini
# API 基础地址，如果使用代理可修改
OPENAI_BASE_URL=https://api.openai.com/v1
